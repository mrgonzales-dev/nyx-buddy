{
  "name": "nyx-dev",
  "version": "0.1.0",
  "description": "Nyx — your local AI dev companion",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && cross-env ELECTRON_DEV=1 electron .\"",
    "electron:build": "vite build && electron .",
    "electron": "electron .",
    "dist:win": "vite build && electron-builder --win --x64",
    "dist:mac": "vite build && electron-builder --mac",
    "dist:linux": "vite build && electron-builder --linux",
    "dist:all": "vite build && electron-builder -mwl"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.1.4",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^26.15.3",
    "vite": "^5.4.11",
    "wait-on": "^8.0.1"
  },
  "dependencies": {
    "highlight.js": "^11.11.1",
    "markdown-it": "^14.3.0",
    "node-llama-cpp": "^3.19.0",
    "turndown": "^7.2.4",
    "vue": "^3.5.13"
  },
  "build": {
    "appId": "com.nyxbuddy.app",
    "productName": "nyx-buddy",
    "copyright": "Copyright © 2026 nyx-buddy",
    "directories": {
      "output": "release",
      "buildResources": "resources"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "resources/logo.txt",
      "resources/model-manifest.json",
      "package.json",
      "!**/.devin/**",
      "!**/.playwright-mcp/**"
    ],
    "extraResources": [
      {
        "from": "resources/logo.txt",
        "to": "logo.txt"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "nyx-buddy"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Development",
      "maintainer": "nyx-buddy"
    }
  }
}
